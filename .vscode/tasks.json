{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ensure RabbitMQ",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$name='smartaudit-rabbitmq'; $exists=docker ps -a --filter \"name=^/$name$\" --format \"{{.Names}}\"; if ($exists -eq $name) { $running=docker ps --filter \"name=^/$name$\" --format \"{{.Names}}\"; if ($running -ne $name) { docker start $name | Out-Null; Write-Host 'RabbitMQ iniciado.' } else { Write-Host 'RabbitMQ ya estaba iniciado.' } } else { docker run -d --name $name --restart unless-stopped -p 5672:5672 -p 15672:15672 rabbitmq:3-management | Out-Null; Write-Host 'RabbitMQ creado e iniciado.' }"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "smartaudit"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend API",
      "type": "process",
      "command": "${workspaceFolder}/Backend/venv/Scripts/python.exe",
      "args": ["-m", "uvicorn", "main:app", "--reload"],
      "options": {
        "cwd": "${workspaceFolder}/Backend"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "smartaudit"
      },
      "problemMatcher": []
    },
    {
      "label": "Celery Worker",
      "type": "process",
      "command": "${workspaceFolder}/Backend/venv/Scripts/python.exe",
      "args": ["-m", "celery", "-A", "celery_worker.celery_app", "worker", "--pool=solo", "--loglevel=info"],
      "options": {
        "cwd": "${workspaceFolder}/Backend"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "smartaudit"
      },
      "problemMatcher": []
    },
    {
      "label": "Frontend Vite",
      "type": "process",
      "command": "npm.cmd",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/Frontend/smart-audit-frontend"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "smartaudit"
      },
      "problemMatcher": []
    },
    {
      "label": "SmartAudit: Arrancar Todo",
      "dependsOn": [
        "Ensure RabbitMQ",
        "Backend API",
        "Celery Worker",
        "Frontend Vite"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
